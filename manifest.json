{
   "content_scripts": [ {
      "all_frames": true,
      "css": [ "style/lookup.css" ],
      "js": [ "include/jquery.min.js", "include/jquery-ui.min.js", "include/lookup.js"],
      "matches": ["*://*/*"] 
   } ],


   "content_security_policy" : {
       "extension_page": "script-src 'self'; object-src 'self'"
   },


   "description": "Web dictionary with context information.",
   "options_page":"options.html",
   "icons": {
      "128": "icon128.png",
      "16": "icon16.png",
      "256": "icon256.png",
      "32": "icon32.png",
      "48": "icon48.png"
   },
   "manifest_version": 3,
   "minimum_chrome_version": "20",
   "name": "Context Dictionary Lookup",
   "permissions": ["storage" ],

   "host_permissions": [
      "*://*/*"
    ],

    "update_url": "http://clients2.google.com/service/update2/crx",
    "version": "8.0.0",
    "web_accessible_resources": [{"resources": [ "img/icon.svg" ,"img/history.png"], 
       "matches": ["https://what-is-this.com/*"]
    }],
   "background":{
       "service_worker": "background_rename.js"
   } 
}
