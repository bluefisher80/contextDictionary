{
   "content_scripts": [ {
      "all_frames": true,
      "css": [ "style/lookup.css" ],
      "js": [ 
          "common/browser-polyfill.js",
          "include/lookup.js"
      ],
      "matches": [ "\u003Call_urls\u003E" ]
   } ],
   "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
   "description": "Web dictionary with context information.",
   "options_page":"options.html",
   "icons": {
      "128": "icon128.png",
      "16": "icon16.png",
      "256": "icon256.png",
      "32": "icon32.png",
      "48": "icon48.png"
   },
   "manifest_version": 2,
   "minimum_chrome_version": "20",
   "name": "Context Dictionary Lookup",
   "permissions": [ "\u003Call_urls\u003E", "unlimitedStorage", "storage", "contextMenus", "activeTab" ],
   "version": "6.2.7",
   "web_accessible_resources": [ "img/icon.svg" ,"img/history.png"],
   "background":{
       "scripts": [
          "common/browser-polyfill.js",
           "background.js"
       ]
   } 
}
